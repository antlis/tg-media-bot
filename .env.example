# Telegram Bot Token (required)
# Get this from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Local Bot API Server (required for docker-compose)
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Local Bot API Server URL (set automatically in docker-compose)
# Leave empty to use standard Telegram API (50MB upload limit)
# API_SERVER_URL=http://localhost:8081

# Temporary directory for downloads
# Default: /tmp/tg-media-bot
TEMP_DIR=/tmp/tg-media-bot

# Maximum concurrent downloads globally
# Default: 3
MAX_PARALLEL_DOWNLOADS=3

# Maximum concurrent downloads per user
# Default: 2
RATE_LIMIT_PER_USER=2

# Download timeout in seconds
# Default: 3600 (1 hour)
DOWNLOAD_TIMEOUT=3600

# Logging level: DEBUG, INFO, WARNING, ERROR
# Default: INFO
LOG_LEVEL=INFO

# Persist logs to a file (in addition to stdout) for a durable download record.
# In Docker this defaults to /data/tg-media-bot.log on a named volume.
# Leave empty to log to stdout only.
# LOG_FILE=/data/tg-media-bot.log

# Use browser cookies for authenticated downloads
# Set to "true" to use Firefox cookies (default)
# Set to "false" to disable
USE_BROWSER_COOKIES=true

# Browser name for cookie extraction
# Options: firefox, chrome, chromium, edge, brave
# Default: firefox
BROWSER_NAME=firefox

# Optional proxy for yt-dlp — used ONLY as a fallback when a download fails with
# a geo/region block (e.g. CIS-licensed tracks). Leave empty to disable.
# Format: socks5h://user:pass@host:port
# PROXY_URL=socks5h://user:pass@host:port
