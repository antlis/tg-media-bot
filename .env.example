# Telegram Bot Token (required)
# Get this from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Temporary directory for downloads
# Default: /tmp/tg-media-bot
TEMP_DIR=/tmp/tg-media-bot

# Maximum file size in MB
# Telegram limits: 50MB for regular users, 2000MB for premium
# Default: 200MB
MAX_FILE_SIZE_MB=200

# Maximum concurrent downloads globally
# Default: 3
MAX_PARALLEL_DOWNLOADS=3

# Maximum concurrent downloads per user
# Default: 2
RATE_LIMIT_PER_USER=2

# Download timeout in seconds
# Default: 3600 (1 hour)
DOWNLOAD_TIMEOUT=3600

# Logging level: DEBUG, INFO, WARNING, ERROR
# Default: INFO
LOG_LEVEL=INFO

# Use browser cookies for authenticated downloads
# Set to "true" to use Firefox cookies (default)
# Set to "false" to disable
USE_BROWSER_COOKIES=true

# Browser name for cookie extraction
# Options: firefox, chrome, chromium, edge, brave
# Default: firefox
BROWSER_NAME=firefox
