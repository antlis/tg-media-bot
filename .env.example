# Telegram Bot Token (required)
# Get this from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Local Bot API Server (required for docker-compose)
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Host port to publish the local Bot API server on (docker-compose only).
# Default 8082 — change if it's already in use on your host.
# BOT_API_HOST_PORT=8082

# Local Bot API Server URL (set automatically in docker-compose)
# Leave empty to use standard Telegram API (50MB upload limit)
# API_SERVER_URL=http://localhost:8081

# Temporary directory for downloads
# Default: /tmp/tg-media-bot
TEMP_DIR=/tmp/tg-media-bot

# Maximum concurrent downloads globally
# Default: 3
MAX_PARALLEL_DOWNLOADS=3

# Maximum concurrent downloads per user
# Default: 2
RATE_LIMIT_PER_USER=2

# Download timeout in seconds
# Default: 3600 (1 hour)
DOWNLOAD_TIMEOUT=3600

# Logging level: DEBUG, INFO, WARNING, ERROR
# Default: INFO
LOG_LEVEL=INFO

# Persist logs to a file (in addition to stdout) for a durable download record.
# In Docker this defaults to /data/tg-media-bot.log on a named volume.
# Leave empty to log to stdout only.
# LOG_FILE=/data/tg-media-bot.log

# Use browser cookies for authenticated downloads
# Set to "true" to use Firefox cookies (default)
# Set to "false" to disable
USE_BROWSER_COOKIES=true

# Browser name for cookie extraction
# Options: firefox, chrome, chromium, edge, brave
# Default: firefox
BROWSER_NAME=firefox

# Path to a Netscape-format cookies.txt for authenticated downloads
# (Instagram, age-restricted media, etc.). Takes precedence over browser
# cookies when the file exists. In Docker this is wired to /cookies/cookies.txt
# (mount a ./cookies dir). Leave empty to disable.
# COOKIES_FILE=/cookies/cookies.txt

# Path to a JSON file persisting group chats an allowed user has activated the
# bot in. In Docker this defaults to /data/allowed_chats.json on a named volume.
# Leave empty to keep activated groups in memory only (lost on restart).
# ALLOWED_CHATS_FILE=/data/allowed_chats.json

# Path to a JSON file caching Telegram file IDs of uploaded media, so repeat
# requests for the same URL are resent instantly (no re-download). In Docker
# this defaults to /data/media_cache.json. Leave empty for in-memory only.
# MEDIA_CACHE_FILE=/data/media_cache.json

# Path to a JSON file persisting chats with minimal UI mode enabled (toggled
# via /minimal on|off): no status/progress messages, no caption on uploaded
# media. In Docker this defaults to /data/minimal_mode.json. Leave empty for
# in-memory only.
# MINIMAL_MODE_FILE=/data/minimal_mode.json

# Docker only: refresh yt-dlp to the latest release on container start (sites
# change often and a pinned yt-dlp silently breaks). Set to "false" to skip the
# update and use the version baked into the image. Default: true.
# YTDLP_AUTO_UPDATE=true

# Optional proxy for yt-dlp — used ONLY as a fallback when a download fails with
# a geo/region block (media licensed only in certain regions). Leave empty to
# disable. Format: socks5h://user:pass@host:port
# PROXY_URL=socks5h://user:pass@host:port
